#!/bin/bash
#***************************************************************************************
# Build XiangShan GSIM emulator
# Prefer: make build-xs-gsim-emu XS_GSIM_EMU_VERSION=<name>
# Usage: ./build_xs_gsim_emu.sh [--skip-pgo]
#***************************************************************************************

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NOOP_HOME="${SCRIPT_DIR}/XiangShan"
GSIM_HOME="${SCRIPT_DIR}/gsim"
DRAMSIM3_HOME="${SCRIPT_DIR}/DRAMsim3"
XS_GSIM_EMU_VERSION="${XS_GSIM_EMU_VERSION:-manual}"

NUM_CORES="${NUM_CORES:-1}"
EMU_THREADS="${EMU_THREADS:-1}"
MAKE_THREADS="${MAKE_THREADS:-200}"
SIM_TOP="${SIM_TOP:-SimTop}"
RTL_SUFFIX="${RTL_SUFFIX:-sv}"
YAML_CONFIG="${YAML_CONFIG:-src/main/resources/config/Default.yml}"
PGO_WORKLOAD="${PGO_WORKLOAD:-${NOOP_HOME}/ready-to-run/coremark-2-iteration.bin}"
LLVM_PROFDATA_BIN="${LLVM_PROFDATA_BIN:-llvm-profdata}"
WITH_CHISELDB="${WITH_CHISELDB:-0}"
SKIP_PGO=0

while [[ $# -gt 0 ]]; do
    case "$1" in
        --skip-pgo)
            SKIP_PGO=1
            shift
            ;;
        *)
            echo "Error: unknown argument: $1"
            echo "Usage: $0 [--skip-pgo]"
            exit 1
            ;;
    esac
done

BUILD_DIR="${NOOP_HOME}/build"
RTL_DIR="${BUILD_DIR}/rtl"
FIR_FILE="${RTL_DIR}/${SIM_TOP}.fir"
SIM_TOP_V="${RTL_DIR}/${SIM_TOP}.${RTL_SUFFIX}"
GENERATED_SRC_DIR="${BUILD_DIR}/generated-src"
DIFFTEST_GEN_CPP="${GENERATED_SRC_DIR}/difftest-extmodule.cpp"
DIFFTEST_MACROS="${GENERATED_SRC_DIR}/DifftestMacros.svh"
CONSTANTIN_CPP="${BUILD_DIR}/constantin.cpp"
CHISEL_DB_CPP="${BUILD_DIR}/chisel_db.cpp"
GSIM_MODEL_DIR="${BUILD_DIR}/gsim-compile/model"
GSIM_MODEL_CPP="${GSIM_MODEL_DIR}/${SIM_TOP}0.cpp"
EMU_BIN="${BUILD_DIR}/gsim-compile/emu"
EMU_LINK="${BUILD_DIR}/emu"
GSIM_OBJ_SIGNATURE_FILE="${BUILD_DIR}/gsim-compile/.build_xs_gsim_emu.signature"
DRAMSIM3_SO="${DRAMSIM3_HOME}/build/libdramsim3.so"
DRAMSIM3_A="${DRAMSIM3_HOME}/build/libdramsim3.a"

XLANG_RTL_INPUTS=(
    "${NOOP_HOME}/Makefile"
    "${NOOP_HOME}/build.sc"
    "${NOOP_HOME}/src/main"
    "${NOOP_HOME}/src/test"
)

DIFFTEST_GEN_INPUTS=(
    "${NOOP_HOME}/difftest/Makefile"
    "${NOOP_HOME}/difftest/build.sc"
    "${NOOP_HOME}/difftest/src/main"
)

EMU_INPUTS=(
    "${NOOP_HOME}/difftest/Makefile"
    "${NOOP_HOME}/difftest/emu.mk"
    "${NOOP_HOME}/difftest/gsim.mk"
    "${NOOP_HOME}/difftest/config"
    "${NOOP_HOME}/difftest/src/test/csrc/common"
    "${NOOP_HOME}/difftest/src/test/csrc/difftest"
    "${NOOP_HOME}/difftest/src/test/csrc/emu"
    "${NOOP_HOME}/difftest/src/test/csrc/gsim"
    "${GENERATED_SRC_DIR}"
    "${CONSTANTIN_CPP}"
    "${BUILD_DIR}/constantin.hpp"
    "${BUILD_DIR}/constantin.txt"
    "${DRAMSIM3_HOME}/build"
)

if [ "${WITH_CHISELDB}" -eq 1 ]; then
    EMU_INPUTS+=(
        "${CHISEL_DB_CPP}"
        "${BUILD_DIR}/chisel_db.h"
    )
fi

XIANGSHAN_MAKE_ARGS=(
    "NOOP_HOME=${NOOP_HOME}"
    "GSIM=1"
    "NUM_CORES=${NUM_CORES}"
    "EMU_THREADS=${EMU_THREADS}"
    "WITH_DRAMSIM3=1"
    "WITH_CHISELDB=${WITH_CHISELDB}"
    "DRAMSIM3_HOME=${DRAMSIM3_HOME}"
    "EMU_TRACE=fst"
    "YAML_CONFIG=${YAML_CONFIG}"
    "LLVM_PROFDATA=${LLVM_PROFDATA_BIN}"
)

DIFFTEST_MAKE_ARGS=(
    "NOOP_HOME=${NOOP_HOME}"
    "DESIGN_DIR=${NOOP_HOME}"
    "SIM_TOP=${SIM_TOP}"
    "GSIM=1"
    "NUM_CORES=${NUM_CORES}"
    "EMU_THREADS=${EMU_THREADS}"
    "RTL_SUFFIX=${RTL_SUFFIX}"
    "WITH_DRAMSIM3=1"
    "WITH_CHISELDB=${WITH_CHISELDB}"
    "DRAMSIM3_HOME=${DRAMSIM3_HOME}"
    "EMU_TRACE=fst"
    "LLVM_PROFDATA=${LLVM_PROFDATA_BIN}"
)

if [ "${SKIP_PGO}" -eq 0 ]; then
    XIANGSHAN_MAKE_ARGS+=("PGO_WORKLOAD=${PGO_WORKLOAD}")
    DIFFTEST_MAKE_ARGS+=("PGO_WORKLOAD=${PGO_WORKLOAD}")
fi

DIFFTEST_VERILOG_ARGS=(
    "NOOP_HOME=${NOOP_HOME}"
    "DESIGN_DIR=${NOOP_HOME}"
    "NUM_CORES=${NUM_CORES}"
    "CONFIG=G"
)

missing_file() {
    local path
    for path in "$@"; do
        if [ ! -e "${path}" ]; then
            return 0
        fi
    done
    return 1
}

first_newer_input() {
    local target="$1"
    shift
    local path newer
    for path in "$@"; do
        if [ ! -e "${path}" ]; then
            continue
        fi
        if [ -d "${path}" ]; then
            newer="$(find "${path}" -type f -newer "${target}" -print -quit 2>/dev/null || true)"
            if [ -n "${newer}" ]; then
                printf '%s\n' "${newer}"
                return 0
            fi
        elif [ "${path}" -nt "${target}" ]; then
            printf '%s\n' "${path}"
            return 0
        fi
    done
    return 1
}

relpath() {
    local path="$1"
    path="${path#${SCRIPT_DIR}/}"
    path="${path#${NOOP_HOME}/}"
    printf '%s\n' "${path}"
}

print_reason() {
    local prefix="$1"
    local reason="$2"
    echo "${prefix}: $(relpath "${reason}")"
}

write_signature() {
    mkdir -p "$(dirname "${GSIM_OBJ_SIGNATURE_FILE}")"
    cat > "${GSIM_OBJ_SIGNATURE_FILE}" <<EOF
NUM_CORES=${NUM_CORES}
EMU_THREADS=${EMU_THREADS}
SIM_TOP=${SIM_TOP}
RTL_SUFFIX=${RTL_SUFFIX}
WITH_DRAMSIM3=1
WITH_CHISELDB=${WITH_CHISELDB}
YAML_CONFIG=${YAML_CONFIG}
EMU_TRACE=fst
EOF
}

signature_matches() {
    [ -f "${GSIM_OBJ_SIGNATURE_FILE}" ] || return 1
    local expected current
    expected="$(
        cat <<EOF
NUM_CORES=${NUM_CORES}
EMU_THREADS=${EMU_THREADS}
SIM_TOP=${SIM_TOP}
RTL_SUFFIX=${RTL_SUFFIX}
WITH_DRAMSIM3=1
WITH_CHISELDB=${WITH_CHISELDB}
YAML_CONFIG=${YAML_CONFIG}
EMU_TRACE=fst
EOF
    )"
    current="$(cat "${GSIM_OBJ_SIGNATURE_FILE}")"
    [ "${current}" = "${expected}" ]
}

# Add gsim to PATH
if [ -d "${GSIM_HOME}/build/gsim" ]; then
    export PATH="${GSIM_HOME}/build/gsim:${PATH}"
fi

# Export required paths
export NOOP_HOME
export GSIM_HOME
export DRAMSIM3_HOME

echo "============================================"
echo "Building XiangShan GSIM Emulator"
echo "============================================"
echo "NOOP_HOME:     ${NOOP_HOME}"
echo "GSIM_HOME:     ${GSIM_HOME}"
echo "DRAMSIM3_HOME: ${DRAMSIM3_HOME}"
echo "VERSION:       ${XS_GSIM_EMU_VERSION}"
if [ "${SKIP_PGO}" -eq 0 ]; then
    echo "PGO_WORKLOAD:  ${PGO_WORKLOAD}"
else
    echo "PGO_WORKLOAD:  <disabled>"
fi
echo "============================================"
echo ""

# Check prerequisites
if [ ! -d "${NOOP_HOME}" ]; then
    echo "Error: XiangShan not found at ${NOOP_HOME}"
    exit 1
fi

if [ ! -d "${GSIM_HOME}" ]; then
    echo "Error: gsim not found at ${GSIM_HOME}"
    exit 1
fi

if [ ! -d "${DRAMSIM3_HOME}" ]; then
    echo "Error: DRAMsim3 not found at ${DRAMSIM3_HOME}"
    exit 1
fi

if [ ! -f "${NOOP_HOME}/${YAML_CONFIG}" ]; then
    echo "Error: YAML config not found at ${NOOP_HOME}/${YAML_CONFIG}"
    exit 1
fi

if [ "${SKIP_PGO}" -eq 0 ]; then
    if [ ! -f "${PGO_WORKLOAD}" ]; then
        echo "Error: PGO workload not found at ${PGO_WORKLOAD}"
        exit 1
    fi
fi

# Build GSIM if needed
if [ ! -f "${GSIM_HOME}/build/gsim/gsim" ]; then
    echo "Building GSIM..."
    make -C "${SCRIPT_DIR}" build-gsim
    echo ""
fi

# Build DRAMsim3 if needed
if [ ! -f "${DRAMSIM3_SO}" ] && [ ! -f "${DRAMSIM3_A}" ]; then
    echo "Building DRAMsim3..."
    make -C "${SCRIPT_DIR}" build-dramsim3
    echo ""
fi

need_sim_verilog=0
need_difftest_verilog=0
need_emu=0
need_gsim_obj_clean=0

required_generated_artifacts=(
    "${FIR_FILE}"
    "${SIM_TOP_V}"
    "${DIFFTEST_GEN_CPP}"
    "${DIFFTEST_MACROS}"
    "${CONSTANTIN_CPP}"
)

if [ "${WITH_CHISELDB}" -eq 1 ]; then
    required_generated_artifacts+=("${CHISEL_DB_CPP}")
fi

if missing_file "${required_generated_artifacts[@]}"; then
    need_sim_verilog=1
    echo "Regenerating XiangShan RTL and generated-src: missing build artifacts"
elif newer_input="$(first_newer_input "${FIR_FILE}" "${XLANG_RTL_INPUTS[@]}" "${NOOP_HOME}/${YAML_CONFIG}")"; then
    need_sim_verilog=1
    print_reason "Regenerating XiangShan RTL and generated-src" "${newer_input}"
fi

if [ "${need_sim_verilog}" -eq 0 ]; then
    if newer_input="$(first_newer_input "${DIFFTEST_GEN_CPP}" "${DIFFTEST_GEN_INPUTS[@]}")"; then
        need_difftest_verilog=1
        print_reason "Refreshing difftest generated-src" "${newer_input}"
    fi
fi

if [ "${need_sim_verilog}" -eq 1 ]; then
    make -C "${NOOP_HOME}" -j"${MAKE_THREADS}" sim-verilog "${XIANGSHAN_MAKE_ARGS[@]}"
    echo ""
fi

if [ "${need_difftest_verilog}" -eq 1 ]; then
    make -C "${NOOP_HOME}/difftest" -j"${MAKE_THREADS}" difftest_verilog "${DIFFTEST_VERILOG_ARGS[@]}"
    echo ""
fi

if [ "${need_sim_verilog}" -eq 1 ] || [ "${need_difftest_verilog}" -eq 1 ]; then
    need_emu=1
elif [ ! -x "${EMU_BIN}" ]; then
    need_emu=1
    echo "Building GSIM emulator: missing ${EMU_BIN}"
elif [ ! -f "${GSIM_MODEL_CPP}" ] || [ "${FIR_FILE}" -nt "${GSIM_MODEL_CPP}" ]; then
    need_emu=1
    echo "Building GSIM emulator: GSIM model is stale"
elif newer_input="$(first_newer_input "${EMU_BIN}" "${EMU_INPUTS[@]}" "${GSIM_MODEL_DIR}")"; then
    need_emu=1
    print_reason "Building GSIM emulator" "${newer_input}"
fi

if ! signature_matches; then
    need_emu=1
    need_gsim_obj_clean=1
    echo "Building GSIM emulator: gsim object build options changed"
fi

if [ "${need_emu}" -eq 1 ]; then
    if [ "${need_gsim_obj_clean}" -eq 1 ]; then
        make -C "${NOOP_HOME}/difftest" -j"${MAKE_THREADS}" gsim-clean-obj "${DIFFTEST_MAKE_ARGS[@]}"
    fi
    make -C "${NOOP_HOME}/difftest" -j"${MAKE_THREADS}" emu "${DIFFTEST_MAKE_ARGS[@]}"
    write_signature
    echo ""
else
    echo "GSIM emulator is up to date."
    echo ""
fi

ln -sfn "${EMU_BIN}" "${EMU_LINK}"

echo "============================================"
echo "Build Complete!"
echo "Emulator: ${NOOP_HOME}/build/emu"
echo "============================================"
